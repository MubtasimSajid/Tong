<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="ap_main" prefHeight="400" prefWidth="450" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DMController">
    <children>
        <Label fx:id="headLabel" layoutX="150.0" layoutY="10.0" text="Direct Message">
            <font>
                <Font name="Ebrima Bold" size="20.0" />
            </font>
        </Label>

        <ScrollPane fx:id="sp_main" fitToWidth="true" layoutX="25.0" layoutY="50.0" prefHeight="280" prefWidth="400.0">
            <content>
                <VBox fx:id="vbox_messages" prefHeight="275" prefWidth="395.0" />
            </content>
        </ScrollPane>

        <TextField fx:id="tf_message" layoutX="25.0" layoutY="345" prefHeight="26" prefWidth="320.0" />
        <Button fx:id="button_send" layoutX="355" layoutY="345" onAction="#sendMessage" text="Send" />
    </children>
</AnchorPane>
