<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="520.0" prefWidth="380.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.RegistrationController">
    <top>
        <Label alignment="CENTER" text="Create Account" textAlignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="80.0" left="105.0" top="50.0" />
            </BorderPane.margin>
            <font>
                <Font name="Nirmala UI" size="24.0" />
            </font>
        </Label>
    </top>
    <center>
        <VBox maxHeight="300.0" prefHeight="300.0" prefWidth="300.0" spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <TextField fx:id="txtf_displayName" prefHeight="25.0" prefWidth="219.0" promptText="Display Name" />
                <TextField fx:id="txtf_fullName" prefHeight="25.0" prefWidth="219.0" promptText="Full Name" />
                <TextField fx:id="txtf_studentID" prefHeight="25.0" prefWidth="219.0" promptText="Student ID" />
                <TextField fx:id="txtf_emailAddress" prefHeight="25.0" prefWidth="219.0" promptText="Email Address" />
                <PasswordField fx:id="pwf_password" prefHeight="25.0" prefWidth="230.0" promptText="Password" />
            </children>
            <BorderPane.margin>
                <Insets bottom="10.0" left="40.0" right="40.0" top="40.0" />
            </BorderPane.margin>
        </VBox>
    </center>
    <bottom>
        <VBox maxHeight="140.0" prefHeight="140.0" prefWidth="380.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="wrongLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="340.0" text="" textFill="RED" visible="false" wrapText="true">
                <VBox.margin>
                    <Insets bottom="10.0" left="20.0" right="20.0" top="25.0" />
                </VBox.margin>
                <font>
                    <Font name="Nirmala UI" size="16.0" />
                </font>
                </Label>
                <HBox alignment="CENTER" prefHeight="50.0" prefWidth="380.0" spacing="20.0">
                <children>
                    <Button fx:id="registerBtn" defaultButton="true" mnemonicParsing="false" onAction="#handleRegister" text="Register" wrapText="true">
                        <font>
                            <Font name="Nirmala UI" size="12.0" />
                        </font>
                    </Button>
                    <Button fx:id="goBackBtn" mnemonicParsing="false" onAction="#loadLogin" text="Go Back">
                        <font>
                            <Font name="Nirmala UI" size="12.0" />
                        </font>
                    </Button>
                </children>
                <VBox.margin>
                    <Insets bottom="30.0" top="10.0" />
                </VBox.margin>
                </HBox>
            <Region prefHeight="200.0" prefWidth="200.0">
               <padding>
                  <Insets top="60.0" />
               </padding>
            </Region>
            </children>
        </VBox>
    </bottom>
</BorderPane>
