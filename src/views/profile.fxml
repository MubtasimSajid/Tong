<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="20.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ProfileController">
   <children>
      <Label alignment="CENTER" text="👤 Edit Profile">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>

      <VBox alignment="CENTER" spacing="10.0">
         <children>
            <Label style="-fx-text-fill: #6c757d;" text="Current Display Name:" />
            <TextField fx:id="tf_currentDisplayName" alignment="CENTER" editable="false" maxWidth="280.0" prefHeight="35.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;" text="Loading...">
            </TextField>
         </children>
      </VBox>

      <VBox alignment="CENTER" spacing="10.0">
         <children>
            <Label style="-fx-text-fill: #6c757d;" text="New Display Name:" />
            <TextField fx:id="tf_newDisplayName" alignment="CENTER" maxWidth="280.0" prefHeight="35.0" promptText="Enter new display name" style="-fx-border-color: #dee2e6; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6;">
            </TextField>
            <Label maxWidth="300.0" style="-fx-text-fill: #fd7e14; -fx-font-size: 11px;" text="⚠️ No 9 consecutive digits allowed" textAlignment="CENTER" wrapText="true">
            </Label>
         </children>
      </VBox>

      <VBox alignment="CENTER" spacing="8.0">
         <children>
            <Label style="-fx-text-fill: #6c757d;" text="Quick Options:" />
            <CheckBox fx:id="cb_useRealName" text="Use Real Name" />
            <CheckBox fx:id="cb_useStudentID" text="Use Student ID" />
         </children>
      </VBox>

      <VBox alignment="CENTER" spacing="10.0">
         <children>
            <Button fx:id="btn_updateDisplayName" onAction="#updateDisplayName" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="✏️ Update Display Name">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
            <Button fx:id="btn_cancel" onAction="#cancelUpdate" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 8;" text="Cancel">
               <font>
                  <Font size="12.0" />
               </font>
            </Button>
         </children>
      </VBox>

      <Label fx:id="lbl_displayNameStatus" alignment="CENTER" maxWidth="320.0" text="" textAlignment="CENTER" wrapText="true">
         <font>
            <Font size="12.0" />
         </font>
      </Label>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
